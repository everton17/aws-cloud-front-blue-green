<mxfile host="app.diagrams.net" type="device">
  <diagram id="cf-bluegreen-arch" name="CloudFront Blue/Green Architecture">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ==================== LAYER TITLES ==================== -->
        <mxCell id="title-user" value="👥 Users" style="fontSize=14;fontStyle=1;fontColor=#333333;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="20" y="30" width="100" height="30" as="geometry" />
        </mxCell>

        <mxCell id="title-cicd" value="🔄 CI/CD (GitHub)" style="fontSize=14;fontStyle=1;fontColor=#333333;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="20" y="140" width="150" height="30" as="geometry" />
        </mxCell>

        <mxCell id="title-aws-edge" value="🌐 AWS Edge & Services" style="fontSize=14;fontStyle=1;fontColor=#333333;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="20" y="280" width="200" height="30" as="geometry" />
        </mxCell>

        <mxCell id="title-storage" value="💾 Storage (S3 Buckets)" style="fontSize=14;fontStyle=1;fontColor=#333333;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="20" y="570" width="200" height="30" as="geometry" />
        </mxCell>

        <!-- ==================== LAYER 1: USERS ==================== -->
        <mxCell id="viewer" value="Visitante" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3E;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.user;" vertex="1" parent="1">
          <mxGeometry x="200" y="40" width="80" height="80" as="geometry" />
        </mxCell>

        <!-- ==================== LAYER 2: CI/CD (GITHUB) ==================== -->
        <mxCell id="grp-github" value="GitHub Repository & Actions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#24292E;strokeWidth=2;dashed=0;verticalAlign=top;fontStyle=1;fontColor=#24292E;align=left;spacingLeft=15;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="140" y="160" width="580" height="100" as="geometry" />
        </mxCell>

        <mxCell id="repo" value="Code Repository" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#24292E;fontColor=#24292E;fontSize=11;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="170" y="185" width="140" height="60" as="geometry" />
        </mxCell>

        <mxCell id="gha" value="GitHub Actions&#10;Workflows&#10;(OIDC Auto-auth)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2088FF;strokeColor=#0969DA;fontColor=#ffffff;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="175" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- ==================== LAYER 3: AWS SERVICES ==================== -->
        <!-- DNS & Security -->
        <mxCell id="route53" value="Route 53&#10;DNS" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#8C4FFF;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.route_53;" vertex="1" parent="1">
          <mxGeometry x="150" y="310" width="80" height="80" as="geometry" />
        </mxCell>

        <mxCell id="acm" value="ACM&#10;Certificates" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.certificate_manager;" vertex="1" parent="1">
          <mxGeometry x="290" y="310" width="80" height="80" as="geometry" />
        </mxCell>

        <!-- Main CloudFront & Lambda -->
        <mxCell id="cloudfront" value="CloudFront&#10;Distribution" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#8C4FFF;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudfront;" vertex="1" parent="1">
          <mxGeometry x="430" y="310" width="80" height="80" as="geometry" />
        </mxCell>

        <mxCell id="lambda" value="Lambda@Edge&#10;origin-request" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;" vertex="1" parent="1">
          <mxGeometry x="570" y="310" width="80" height="80" as="geometry" />
        </mxCell>

        <!-- Configuration & Control -->
        <mxCell id="ssm" value="SSM Parameter&#10;Store&#10;/Rollback" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#E7157B;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.systems_manager_parameter_store;" vertex="1" parent="1">
          <mxGeometry x="710" y="310" width="80" height="80" as="geometry" />
        </mxCell>

        <mxCell id="iam" value="IAM OIDC&#10;Provider +&#10;Role" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.identity_and_access_management_iam;" vertex="1" parent="1">
          <mxGeometry x="850" y="310" width="80" height="80" as="geometry" />
        </mxCell>

        <!-- ==================== LAYER 4: S3 BUCKETS ==================== -->
        <mxCell id="s3main" value="S3 Bucket&#10;main (GREEN)&#10;Current Version" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;" vertex="1" parent="1">
          <mxGeometry x="240" y="600" width="100" height="100" as="geometry" />
        </mxCell>

        <mxCell id="s3roll" value="S3 Bucket&#10;rollback (BLUE)&#10;Previous Version" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;" vertex="1" parent="1">
          <mxGeometry x="480" y="600" width="100" height="100" as="geometry" />
        </mxCell>

        <mxCell id="s3ver" value="S3 Bucket&#10;versions&#10;Archives (.tar.gz)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=10;fontStyle=1;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;" vertex="1" parent="1">
          <mxGeometry x="720" y="600" width="100" height="100" as="geometry" />
        </mxCell>

        <!-- ==================== CONNECTIONS: REQUEST FLOW ==================== -->
        <!-- Visitor to Route53 -->
        <mxCell id="e-viewer-r53" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;fontSize=10;fontColor=#333333;fontStyle=1;startArrow=none;dashed=0;" edge="1" parent="1" source="viewer" target="route53">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="200" y="280" />
              <mxPoint x="190" y="280" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Route53 to CloudFront -->
        <mxCell id="e-r53-cf" value="① DNS alias" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;fontSize=10;fontColor=#333333;fontStyle=1;" edge="1" parent="1" source="route53" target="cloudfront">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="190" y="420" />
              <mxPoint x="470" y="420" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ACM to CloudFront (optional) -->
        <mxCell id="e-acm-cf" value="② TLS cert" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=none;dashed=1;strokeWidth=2;fontSize=10;fontColor=#DD344C;strokeColor=#DD344C;" edge="1" parent="1" source="acm" target="cloudfront">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="330" y="350" />
              <mxPoint x="430" y="350" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- CloudFront to Lambda -->
        <mxCell id="e-cf-lambda" value="③ origin-request" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;fontSize=10;fontColor=#333333;fontStyle=1;" edge="1" parent="1" source="cloudfront" target="lambda">
          <mxGeometry relative="1" as="geometry">
            <Array as="points" />
          </mxGeometry>
        </mxCell>

        <!-- Lambda to SSM -->
        <mxCell id="e-lambda-ssm" value="④ reads (cache ~60s)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;fontSize=9;fontColor=#333333;fontStyle=0;" edge="1" parent="1" source="lambda" target="ssm">
          <mxGeometry relative="1" as="geometry">
            <Array as="points" />
          </mxGeometry>
        </mxCell>

        <!-- Lambda to S3 Main (green) -->
        <mxCell id="e-lambda-main" value="⑤ false → GREEN" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;fontSize=10;fontColor=#1A7F37;strokeColor=#1A7F37;fontStyle=1;" edge="1" parent="1" source="lambda" target="s3main">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="610" y="520" />
              <mxPoint x="290" y="520" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Lambda to S3 Rollback (blue) -->
        <mxCell id="e-lambda-roll" value="⑥ true → BLUE" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;fontSize=10;fontColor=#0969DA;strokeColor=#0969DA;fontStyle=1;" edge="1" parent="1" source="lambda" target="s3roll">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="610" y="540" />
              <mxPoint x="530" y="540" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ==================== CONNECTIONS: CI/CD FLOW ==================== -->
        <!-- Repo to Actions -->
        <mxCell id="e-repo-gha" value="push / trigger" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;fontSize=10;fontColor=#24292E;fontStyle=0;" edge="1" parent="1" source="repo" target="gha">
          <mxGeometry relative="1" as="geometry">
            <Array as="points" />
          </mxGeometry>
        </mxCell>

        <!-- Actions to IAM (OIDC) -->
        <mxCell id="e-gha-iam" value="⓵ OIDC&#10;AssumeRole" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;dashed=1;strokeWidth=2;fontSize=9;fontColor=#DD344C;strokeColor=#DD344C;fontStyle=0;" edge="1" parent="1" source="gha" target="iam">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="540" y="280" />
              <mxPoint x="890" y="280" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Actions to S3 Main -->
        <mxCell id="e-gha-s3main" value="⓶ build &amp; sync" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;fontSize=9;fontColor=#7AA116;strokeColor=#7AA116;fontStyle=0;" edge="1" parent="1" source="gha" target="s3main">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="460" y="260" />
              <mxPoint x="290" y="260" />
              <mxPoint x="290" y="600" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Actions to S3 Versions -->
        <mxCell id="e-gha-s3ver" value="⓷ archive" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;fontSize=9;fontColor=#7AA116;strokeColor=#7AA116;fontStyle=0;" edge="1" parent="1" source="gha" target="s3ver">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="530" y="260" />
              <mxPoint x="770" y="260" />
              <mxPoint x="770" y="600" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Actions to SSM -->
        <mxCell id="e-gha-ssm" value="⓸ toggle" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;fontSize=9;fontColor=#E7157B;strokeColor=#E7157B;fontStyle=0;" edge="1" parent="1" source="gha" target="ssm">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="460" y="270" />
              <mxPoint x="750" y="270" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Actions to CloudFront -->
        <mxCell id="e-gha-cf" value="⓹ invalidate" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;fontSize=9;fontColor=#8C4FFF;strokeColor=#8C4FFF;fontStyle=0;" edge="1" parent="1" source="gha" target="cloudfront">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="460" y="255" />
              <mxPoint x="470" y="255" />
              <mxPoint x="470" y="310" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ==================== LEGEND ==================== -->
        <mxCell id="legend-title" value="📖 Legend" style="fontSize=12;fontStyle=1;fontColor=#333333;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1020" y="310" width="100" height="25" as="geometry" />
        </mxCell>

        <mxCell id="legend-request" value="User Request Flow (steps ①-⑥)" style="fontSize=10;fontColor=#333333;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1020" y="345" width="280" height="25" as="geometry" />
        </mxCell>

        <mxCell id="legend-cicd" value="CI/CD Deployment Flow (steps ⓵-⓹)" style="fontSize=10;fontColor=#333333;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1020" y="380" width="280" height="25" as="geometry" />
        </mxCell>

        <mxCell id="legend-green" value="GREEN = Current (main) bucket" style="fontSize=10;fontColor=#1A7F37;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1020" y="415" width="280" height="25" as="geometry" />
        </mxCell>

        <mxCell id="legend-blue" value="BLUE = Rollback (previous) bucket" style="fontSize=10;fontColor=#0969DA;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1020" y="450" width="280" height="25" as="geometry" />
        </mxCell>

        <mxCell id="legend-archive" value="Archive = Historical version backups" style="fontSize=10;fontColor=#7AA116;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1020" y="485" width="280" height="25" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
